# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# -------------------------------------------------------
# Arquivos internos de desenvolvimento — não vão pro repo
# -------------------------------------------------------

# Antigravity ECC (framework do agente de IA) — repo aninhado, nunca commitar
/ecc/
/~/

# Documentação interna e vault Obsidian
/_memoria/
/.obsidian/

# Referências visuais e inspirações de design
/inspirações/

# Assets fora da estrutura do Next.js (ícone deve estar em /public/)
/Assets/

# Logs de debug do editor/build
ts_errors.txt
build_error.txt
lint-errors.txt

# Antigravity/Claude logs and settings
.claude/
scratch/
runtime-logs.json
*.csv
*.log

# Sentry Config File
.env.sentry-build-plugin
